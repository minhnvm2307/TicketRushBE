APP_NAME=TicketRush API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ticketrush
REDIS_URL=redis://redis:6379/0
HOLD_DURATION_MINUTES=10
QUEUE_THRESHOLD=200
QUEUE_BATCH_SIZE=50
QUEUE_TOKEN_TTL_MINUTES=15
ENABLE_REDIS=true
DEFAULT_ADMIN_EMAIL=admin@ticketrush.local
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_NAME=System Admin
