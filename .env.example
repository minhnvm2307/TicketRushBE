APP_NAME=TicketRush API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api
CORS_ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
JWT_SECRET_KEY=123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ticketrush
REDIS_URL=redis://redis:6379/0
HOLD_DURATION_MINUTES=10
QUEUE_THRESHOLD=200
QUEUE_BATCH_SIZE=50
QUEUE_TOKEN_TTL_MINUTES=15
ENABLE_REDIS=true

# Seed users
DEFAULT_ADMIN_EMAIL=admin@ticketrush.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_USER_EMAIL=user@gmail.com
DEFAULT_USER_PASSWORD=User@123456
DEFAULT_USER_NAME=Nguyen Van A

# Embedding mode
# - http: call embedding service over HTTP (recommended for lightweight API image)
# - onnx: run ONNX model directly in API process
EMBEDDING_PROVIDER=http
EMBEDDING_SERVICE_URL=http://embedding:80
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_TIMEOUT_SECONDS=5
EMBEDDING_ONNX_MODEL_PATH=/models/model.onnx
EMBEDDING_ONNX_TOKENIZER_PATH=/models/tokenizer.json
EMBEDDING_DIMENSION=384
EMBEDDING_SIMILARITY_THRESHOLD=0.5
